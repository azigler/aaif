# Private / local-only harness state (Asana IDs, secrets, notes) — NEVER committed
.local/

# Secrets / env
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Scratch
scratch/
*.tmp

