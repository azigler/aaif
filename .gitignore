# Private / local-only harness state (Asana IDs, secrets, notes) — NEVER committed
.local/

# Secrets / env
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Scratch
scratch/
*.tmp

# beads local db (the JSONL is the source of truth, committed; the SQLite is derived)
.beads/*.db
.beads/*.db-shm
.beads/*.db-wal

# bv (beads viewer) local config and caches
.bv/

# working submission drafts are premature — stage via private gists for review, never commit until shipped
# EXCEPTION: the MCP governance whitepaper is a deliberate public open-learning artifact (Zig 2026-07-16) —
# the /research-paper pipeline + this scaffold are shared in the open on purpose.
submissions/*
!submissions/2026-mcp-governance-whitepaper/
